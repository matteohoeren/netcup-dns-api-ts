# Environment variables for integration testing
# Copy this to .env.local and fill in your actual credentials
# DO NOT commit .env.local to version control!

NETCUP_CUSTOMER_NUMBER=your_customer_number_here
NETCUP_API_KEY=your_api_key_here
NETCUP_API_PASSWORD=your_api_password_here

# Optional integration-test controls for non-dangerous API suite
NETCUP_TEST_DOMAIN=example.com
NETCUP_TEST_TLD=de
NETCUP_TEST_HANDLE_ID=123456
NETCUP_TEST_ALLOW_MUTATION=false
NETCUP_TEST_ALLOW_ACKPOLL=false
